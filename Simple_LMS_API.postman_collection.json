        {
          "name": "List Courses",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has pagination', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('page');",
                  "    pm.expect(json).to.have.property('limit');",
                  "});",
                  "",
                  "pm.test('Data is an array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});",
                  "",
                  "// Save first course ID if exists",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('course_id', json.data[0].id);",
                  "    console.log('\u2705 course_id saved:', json.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
